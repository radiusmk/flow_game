<Window x:Class="FlowGame.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flow Game" Height="820" MinHeight="640" Width="1120" MinWidth="920"
        Background="#101418" Foreground="#F3F6F8"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="#26313A" />
            <Setter Property="Foreground" Value="#F3F6F8" />
            <Setter Property="BorderBrush" Value="#3B4A55" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Background" Value="#F3F6F8" />
            <Setter Property="Foreground" Value="#101418" />
            <Setter Property="BorderBrush" Value="#6D7B86" />
            <Setter Property="TextElement.Foreground" Value="#101418" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#F3F6F8" />
            <Setter Property="Foreground" Value="#101418" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6F8" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#171D22" Padding="22">
            <StackPanel>
                <TextBlock Text="Flow Game" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,22" />

                <TextBlock Text="Nivel" Foreground="#AAB7C1" />
                <ComboBox x:Name="StartLevelCombo" SelectionChanged="StartLevelCombo_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#101418" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Content="Recarregar nivel" Click="NewGame_Click" />
                <Button Content="Reiniciar" Click="Reset_Click" />
                <Button Content="Desfazer" Click="Undo_Click" />
                <Button Content="Usar dica" Click="UseHint_Click" />

                <Separator Margin="0,18" Background="#33414A" />

                <TextBlock x:Name="LevelText" FontSize="18" FontWeight="SemiBold" />
                <TextBlock x:Name="SizeText" Margin="0,8,0,0" Foreground="#AAB7C1" />
                <TextBlock x:Name="SolvedText" Margin="0,4,0,0" Foreground="#AAB7C1" />
                <TextBlock x:Name="ScoreText" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#FDD835" />
                <TextBlock x:Name="CreditsText" Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#8DE3C7" />
                <TextBlock x:Name="StatusText" Margin="0,18,0,0" TextWrapping="Wrap" Foreground="#DDE6EE" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Border Background="#0C0F12" BorderBrush="#29343C" BorderThickness="1">
                <Viewbox Stretch="Uniform">
                    <Canvas x:Name="BoardCanvas"
                            Width="720"
                            Height="720"
                            Background="#12171C"
                            MouseLeftButtonDown="BoardCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="BoardCanvas_MouseLeftButtonUp"
                            MouseMove="BoardCanvas_MouseMove"
                            SizeChanged="BoardCanvas_SizeChanged" />
                </Viewbox>
            </Border>
            <Button Content="Ver solucao"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,16"
                    MinWidth="116"
                    Click="ShowSolution_Click" />
        </Grid>
    </Grid>
</Window>
